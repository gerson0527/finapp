EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anon_aqui

# Solo para migraciones locales (npm run db:migrate). No la subas a git.
# Supabase → Settings → Database → Connection string → URI
# Reemplaza [YOUR-PASSWORD] por la contraseña de la base de datos.
SUPABASE_DB_URL=postgresql://postgres:TU_PASSWORD@db.tu-proyecto.supabase.co:5432/postgres

# Borrar datos (requiere --confirm):
# npm run db:clear -- --confirm --full     ← todo nuevo (usuarios + categorías + datos)
# npm run db:clear -- --confirm --users    ← solo borra logins también
